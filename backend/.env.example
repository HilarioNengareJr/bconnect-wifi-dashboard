# Database connection (PostgreSQL is the primary target).
# Host port is 5433 (mapped to the container's 5432) to avoid clashing with
# another local Postgres already on 5432. See docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://bconnect:bconnect@localhost:5433/bconnect

# Set true to simulate a Wi-Fi controller outage on the next sync.
FAIL_SYNC=false

# Allowed frontend origin(s), comma-separated.
CORS_ORIGINS=http://localhost:5173
